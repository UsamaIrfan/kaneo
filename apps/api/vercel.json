{
  "version": 2,
  "buildCommand": "pnpm --filter @kaneo/api build:vercel",
  "builds": [
    {
      "src": "dist/vercel/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/vercel/**", "drizzle/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/vercel/index.js"
    }
  ]
}
